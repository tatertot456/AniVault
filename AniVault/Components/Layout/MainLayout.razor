@inherits LayoutComponentBase
@inject ToastService Toast
@inject NavigationManager Nav
@implements IDisposable

<div class="app-shell">
    <div id="cursor-dot"></div>
    <div id="cursor-ring"></div>

    <nav class="navbar">
        <a class="navbar-brand" href="/">ANI<span>VAULT</span></a>

        <ul class="navbar-nav">
            <li><NavLink href="/" class="nav-link" Match="NavLinkMatch.All">Home</NavLink></li>
            <li><NavLink href="/vault" class="nav-link">Vault</NavLink></li>
            <li><NavLink href="/favorites" class="nav-link">Favorites</NavLink></li>
            <li><NavLink href="/stats" class="nav-link">Stats</NavLink></li>
            <li><NavLink href="/activity" class="nav-link">Activity</NavLink></li>
        </ul>

        <NavSearch />

        <div class="navbar-right">
            <a href="/add-anime" class="dev-badge">＋ Add Anime</a>
            <AuthorizeView>
                <Authorized>
                    <form method="post" action="/logout">
                        <AntiforgeryToken />
                        <button type="submit" class="btn-logout">Sign Out</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn-logout">Sign In</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>

    <main class="page-content">
        @Body
    </main>

    <div class="toast-container">
        @foreach (var toast in Toast.Toasts)
        {
            <div class="toast toast-@toast.Type">
                @toast.Message
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Toast.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Toast.OnChange -= StateHasChanged;
    }
}