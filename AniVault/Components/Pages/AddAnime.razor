@page "/add-anime"
@inject JikanService JikanService
@inject AnimeService AnimeService
@inject ToastService Toast
@rendermode InteractiveServer

<PageTitle>Add Anime — AniVault</PageTitle>

<div class="section">
    <div class="add-anime-header">
        <h1 class="section-title">＋ Add Anime</h1>
        <p class="section-subtitle">Search for anime and add them to your vault.</p>

        <!-- Centered Search Bar -->
        <div class="add-anime-search">
            <div class="dev-search-row">
                <input class="dev-input"
                       type="text"
                       placeholder="Search anime title..."
                       @bind="SearchQuery"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
                <button class="btn btn-gold" @onclick="Search" disabled="@IsSearching">
                    @(IsSearching ? "Searching..." : "Search")
                </button>
            </div>
        </div>
    </div>

    <!-- Search Results Grid -->
    @if (SearchResults.Any())
    {
        <div class="anime-grid">
            @foreach (var result in SearchResults)
            {
                <div class="anime-card @(AddedIds.Contains(result.MalId) ? "add-anime-added" : "")"
                     @onclick="() => OpenAddPanel(result)">
                    @if (!string.IsNullOrWhiteSpace(result.Images?.Jpg?.LargeImageUrl))
                    {
                        <img class="anime-card-poster"
                             src="@result.Images.Jpg.LargeImageUrl"
                             alt="@result.Title poster" />
                    }
                    else
                    {
                        <div class="anime-card-no-art">NO ART</div>
                    }

                    <div class="anime-card-overlay">
                        <p class="anime-card-title">@(result.TitleEnglish ?? result.Title)</p>
                        @if (result.Score.HasValue)
                        {
                            <span class="anime-card-status">⭐ @result.Score.Value.ToString("F1")</span>
                        }
                    </div>

                    <div class="anime-card-hover-info">
                        @if (!string.IsNullOrWhiteSpace(result.Synopsis))
                        {
                            <p class="anime-card-synopsis">@Truncate(result.Synopsis, 180)</p>
                        }
                        @if (result.Genres?.Any() == true)
                        {
                            <span class="anime-card-liked liked-yes">
                                @string.Join(", ", result.Genres.Take(2).Select(g => g.Name))
                            </span>
                        }
                    </div>

                    @if (AddedIds.Contains(result.MalId))
                    {
                        <span class="anime-card-score" style="background:rgba(46,196,182,0.9);color:white">✓</span>
                    }
                    else if (result.Episodes.HasValue)
                    {
                        <span class="anime-card-score">@result.Episodes ep</span>
                    }
                </div>
            }
        </div>
    }
    else if (HasSearched && !IsSearching)
    {
        <div class="empty-state">
            <p>No results found. Try a different title!</p>
        </div>
    }
</div>

<!-- Add Panel Modal -->
@if (SelectedResult != null)
{
    <div class="spotlight-overlay" @onclick="CloseAddPanel">
        <div class="spotlight-panel dev-add-panel" @onclick:stopPropagation="true">
            @if (!string.IsNullOrWhiteSpace(SelectedResult.Images?.Jpg?.LargeImageUrl))
            {
                <div class="spotlight-bg"
                     style="background-image:url('@SelectedResult.Images.Jpg.LargeImageUrl')"></div>
            }
            <button class="spotlight-close" @onclick="CloseAddPanel">✕</button>
            <div class="spotlight-body">
                <div class="spotlight-poster-wrap">
                    @if (!string.IsNullOrWhiteSpace(SelectedResult.Images?.Jpg?.LargeImageUrl))
                    {
                        <img class="spotlight-poster"
                             src="@SelectedResult.Images.Jpg.LargeImageUrl"
                             alt="@SelectedResult.Title" />
                    }
                </div>
                <div class="spotlight-info">
                    <h2 class="spotlight-title">@(SelectedResult.TitleEnglish ?? SelectedResult.Title)</h2>
                    <div class="spotlight-tags" style="margin-bottom:1rem;">
                        @if (SelectedResult.Score.HasValue)
                        {
                            <span class="detail-badge">⭐ @SelectedResult.Score.Value.ToString("F1")</span>
                        }
                        @if (SelectedResult.Episodes.HasValue)
                        {
                            <span class="detail-badge">@SelectedResult.Episodes eps</span>
                        }
                        @if (SelectedResult.Genres?.Any() == true)
                        {
                            @foreach (var g in SelectedResult.Genres)
                            {
                                <span class="genre-tag">@g.Name</span>
                            }
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(SelectedResult.Synopsis))
                    {
                        <p class="spotlight-synopsis">@Truncate(SelectedResult.Synopsis, 200)</p>
                    }
                    <div class="dev-panel-form">
                        <div class="dev-panel-field">
                            <label class="dev-panel-label">Watch Status</label>
                            <select class="dev-select" @bind="NewStatus">
                                <option>Plan to Watch</option>
                                <option>Watching</option>
                                <option>Watched</option>
                                <option>Plan to Read</option>
                                <option>Reading</option>
                                <option>Read</option>
                                <option>On-Hold</option>
                                <option>Dropped</option>
                            </select>
                        </div>
                        <div class="dev-panel-field">
                            <label class="dev-panel-label">My Rating (0–10)</label>
                            <input class="dev-input-small" type="number"
                                   min="0" max="10" step="0.1"
                                   placeholder="Leave blank to rate later"
                                   @bind="NewRating" />
                        </div>
                        <div class="dev-panel-field">
                            <label class="dev-panel-label">Did you like it?</label>
                            <div class="liked-toggle">
                                <button class="liked-btn @(NewLiked == true ? "liked-btn-yes" : "")"
                                        @onclick='() => NewLiked = NewLiked == true ? null : true'>
                                    ♥ Liked
                                </button>
                                <button class="liked-btn @(NewLiked == false ? "liked-btn-no" : "")"
                                        @onclick='() => NewLiked = NewLiked == false ? null : false'>
                                    ✕ Disliked
                                </button>
                                <button class="liked-btn @(NewLiked == null ? "liked-btn-neutral" : "")"
                                        @onclick="() => NewLiked = null">
                                    — Undecided
                                </button>
                            </div>
                        </div>
                        <div class="dev-panel-field">
                            <label class="dev-panel-label">Favorite?</label>
                            <div class="liked-toggle">
                                <button class="liked-btn @(NewFavorite ? "liked-btn-yes" : "")"
                                        @onclick="() => NewFavorite = true">
                                    ★ Yes
                                </button>
                                <button class="liked-btn @(!NewFavorite ? "liked-btn-neutral" : "")"
                                        @onclick="() => NewFavorite = false">
                                    ☆ No
                                </button>
                            </div>
                        </div>
                        <div class="dev-panel-field dev-panel-field-full">
                            <label class="dev-panel-label">Notes</label>
                            <textarea class="dev-textarea" rows="3"
                                      placeholder="Initial thoughts, why you added it..."
                                      @bind="NewNotes"></textarea>
                        </div>
                    </div>
                    <div class="spotlight-actions">
                        <button class="btn btn-gold" @onclick="AddToVault" disabled="@IsAdding">
                            @(IsAdding ? "Adding..." : "+ Add to Vault")
                        </button>
                        <button class="btn btn-back" @onclick="CloseAddPanel">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string SearchQuery = string.Empty;
    private List<JikanAnimeResult> SearchResults = new();
    private bool IsSearching = false;
    private bool HasSearched = false;
    private HashSet<int> AddedIds = new();

    private JikanAnimeResult? SelectedResult;
    private string NewStatus = "Plan to Watch";
    private decimal? NewRating;
    private bool? NewLiked;
    private bool NewFavorite = false;
    private string NewNotes = string.Empty;
    private bool IsAdding = false;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery)) return;
        IsSearching = true;
        HasSearched = true;
        SearchResults = new();
        SearchResults = await JikanService.SearchAsync(SearchQuery);
        IsSearching = false;
    }

    private void OpenAddPanel(JikanAnimeResult result)
    {
        if (AddedIds.Contains(result.MalId)) return;
        SelectedResult = result;
        NewStatus = "Plan to Watch";
        NewRating = null;
        NewLiked = null;
        NewFavorite = false;
        NewNotes = string.Empty;
    }

    private void CloseAddPanel() => SelectedResult = null;

    private async Task AddToVault()
    {
        if (SelectedResult == null) return;
        IsAdding = true;
        var entry = new AnimeEntry
        {
            Title = SelectedResult.TitleEnglish ?? SelectedResult.Title ?? "Unknown",
            CoverImageUrl = SelectedResult.Images?.Jpg?.LargeImageUrl,
            Description = SelectedResult.Synopsis,
            AverageRating = SelectedResult.Score,
            EpisodeCount = SelectedResult.Episodes,
            Genre = SelectedResult.Genres != null
                ? string.Join(", ", SelectedResult.Genres.Select(g => g.Name))
                : null,
            TrailerUrl = SelectedResult.Trailer?.EmbedUrl ?? SelectedResult.Trailer?.Url,
            WatchStatus = NewStatus,
            MyRating = NewRating,
            Liked = NewLiked,
            IsFavorite = NewFavorite,
            Notes = string.IsNullOrWhiteSpace(NewNotes) ? null : NewNotes,
            DateAdded = DateTime.Now
        };
        await AnimeService.AddAsync(entry);
        Toast.Show($"{entry.Title} added to vault!", ToastType.Success);
        AddedIds.Add(SelectedResult.MalId);
        IsAdding = false;
        CloseAddPanel();
    }

    private string Truncate(string? s, int max) =>
        s == null ? "" : s.Length <= max ? s : s[..max].TrimEnd() + "…";
}