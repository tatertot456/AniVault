@page "/vault"
@inject AnimeService AnimeService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Vault — AniVault</PageTitle>

<div class="section">
    <div class="section-header">
        <h1 class="section-title">The Vault</h1>
        <div class="media-toggle">
            <button class="media-toggle-btn @(MediaFilter == "All" ? "media-toggle-active" : "")"
                    @onclick='() => SetMediaFilter("All")'>
                All
            </button>
            <button class="media-toggle-btn @(MediaFilter == "Anime" ? "media-toggle-active" : "")"
                    @onclick='() => SetMediaFilter("Anime")'>
                🎬 Anime
            </button>
            <button class="media-toggle-btn @(MediaFilter == "Manga" ? "media-toggle-active" : "")"
                    @onclick='() => SetMediaFilter("Manga")'>
                📖 Manga
            </button>
        </div>
        <span class="vault-count">@FilteredAnime.Count entries</span>
    </div>

    <div class="vault-controls">
        <div class="vault-search">
            <span class="vault-search-icon">⌕</span>
            <input class="vault-search-input"
                   type="text"
                   placeholder="Search titles..."
                   value="SearchQuery"
                   @oninput="OnSearchInput" />
        </div>
        <select class="dev-select" @bind="SortOrder" @bind:after="ApplyFilter">
            <option value="recent">Recently Added</option>
            <option value="alpha">A → Z</option>
            <option value="rating_desc">My Rating ↓</option>
            <option value="rating_asc">My Rating ↑</option>
            <option value="mal_desc">MAL Score ↓</option>
        </select>
        <button class="btn btn-outline" @onclick="OpenRandomPicker">🎲 Random Pick</button>
    </div>

    <div class="filter-chips">
        <button class="chip @(ActiveFilter == "All" ? "chip-active" : "")" @onclick='() => SetFilter("All")'>
            All <span class="chip-count">@AllAnime.Count</span>
        </button>
        <button class="chip @(ActiveFilter == "Watched" ? "chip-active" : "")" @onclick='() => SetFilter("Watched")'>
            Watched <span class="chip-count">@AllAnime.Count(a => a.Statuses.Any(s => s.StatusType == "Watched"))</span>
        </button>
        <button class="chip @(ActiveFilter == "Watching" ? "chip-active" : "")" @onclick='() => SetFilter("Watching")'>
            Watching <span class="chip-count">@AllAnime.Count(a => a.Statuses.Any(s => s.StatusType == "Watching"))</span>
        </button>
        <button class="chip @(ActiveFilter == "Read" ? "chip-active" : "")" @onclick='() => SetFilter("Read")'>
            Read <span class="chip-count">@AllAnime.Count(a => a.Statuses.Any(s => s.StatusType == "Read"))</span>
        </button>
        <button class="chip @(ActiveFilter == "Reading" ? "chip-active" : "")" @onclick='() => SetFilter("Reading")'>
            Reading <span class="chip-count">@AllAnime.Count(a => a.Statuses.Any(s => s.StatusType == "Reading"))</span>
        </button>
        <button class="chip @(ActiveFilter == "Plan to Watch" ? "chip-active" : "")" @onclick='() => SetFilter("Plan to Watch")'>
            Plan to Watch <span class="chip-count">@AllAnime.Count(a => a.Statuses.Any(s => s.StatusType == "Plan to Watch"))</span>
        </button>
        <button class="chip @(ActiveFilter == "Plan to Read" ? "chip-active" : "")" @onclick='() => SetFilter("Plan to Read")'>
            Plan to Read <span class="chip-count">@AllAnime.Count(a => a.Statuses.Any(s => s.StatusType == "Plan to Read"))</span>
        </button>
        <button class="chip @(ActiveFilter == "On-Hold" ? "chip-active" : "")" @onclick='() => SetFilter("On-Hold")'>
            On-Hold <span class="chip-count">@AllAnime.Count(a => a.Statuses.Any(s => s.StatusType == "On-Hold"))</span>
        </button>
        <button class="chip @(ActiveFilter == "Dropped" ? "chip-active" : "")" @onclick='() => SetFilter("Dropped")'>
            Dropped <span class="chip-count">@AllAnime.Count(a => a.Statuses.Any(s => s.StatusType == "Dropped"))</span>
        </button>
    </div>

    @if (AvailableGenres.Any())
    {
        <div class="genre-filter-row">
            <button class="genre-filter-chip @(ActiveGenre == null ? "genre-filter-active" : "")"
                    @onclick="() => SetGenre(null)">
                All Genres
            </button>
            @foreach (var genre in AvailableGenres)
            {
                <button class="genre-filter-chip @(ActiveGenre == genre ? "genre-filter-active" : "")"
                        @onclick="() => SetGenre(genre)">
                    @genre
                </button>
            }
        </div>
    }

    @if (IsLoading)
    {
        <div class="spinner-container"><div class="spinner"></div></div>
    }
    else if (!FilteredAnime.Any())
    {
        <div class="empty-state"><p>No anime found. Try a different search or filter!</p></div>
    }
    else
    {
        <div class="anime-grid">
            @foreach (var entry in FilteredAnime)
            {
                <div class="anime-card" @onclick="() => OpenSpotlight(entry)">
                    @if (!string.IsNullOrWhiteSpace(entry.CoverImageUrl))
                    {
                        <img class="anime-card-poster"
                             src="@entry.CoverImageUrl"
                             alt="@entry.Title poster"
                             loading="lazy" />
                    }
                    else
                    {
                        <div class="anime-card-no-art">NO ART</div>
                    }
                    <div class="anime-card-overlay">
                        <p class="anime-card-title">@entry.Title</p>
                        <div class="card-status-pills">
                            @foreach (var s in entry.Statuses)
                            {
                                <span class="status-pill @GetStatusClass(s.StatusType)">@s.StatusType</span>
                            }
                        </div>
                    </div>
                    <div class="anime-card-hover-info">
                        @if (!string.IsNullOrWhiteSpace(entry.Description))
                        {
                            <p class="anime-card-synopsis">@Truncate(entry.Description, 180)</p>
                        }
                        @if (entry.Liked.HasValue)
                        {
                            <span class="anime-card-liked @(entry.Liked.Value ? "liked-yes" : "liked-no")">
                                @(entry.Liked.Value ? "♥ Liked" : "✕ Disliked")
                            </span>
                        }
                    </div>
                    @if (entry.MyRating.HasValue)
                    {
                        <span class="anime-card-score">@entry.MyRating.Value.ToString("F1")</span>
                    }
                    <button class="card-fav-btn @(entry.IsFavorite ? "fav-active" : "")"
                            @onclick:stopPropagation="true"
                            @onclick="() => ToggleFavorite(entry)">
                        @(entry.IsFavorite ? "★" : "☆")
                    </button>
                </div>
            }
        </div>
    }
</div>

@if (SpotlightEntry != null)
{
    <div class="spotlight-overlay" @onclick="CloseSpotlight">
        <div class="spotlight-panel" @onclick:stopPropagation="true">
            @if (!string.IsNullOrWhiteSpace(SpotlightEntry.CoverImageUrl))
            {
                <div class="spotlight-bg"
                     style="background-image:url('@SpotlightEntry.CoverImageUrl')"></div>
            }
            <button class="spotlight-close" @onclick="CloseSpotlight">✕</button>
            <div class="spotlight-body">
                <div class="spotlight-poster-wrap">
                    @if (!string.IsNullOrWhiteSpace(SpotlightEntry.CoverImageUrl))
                    {
                        <img class="spotlight-poster"
                             src="@SpotlightEntry.CoverImageUrl"
                             alt="@SpotlightEntry.Title" />
                    }
                </div>
                <div class="spotlight-info">
                    <div class="card-status-pills" style="margin-bottom:0.75rem;">
                        @foreach (var s in SpotlightEntry.Statuses)
                        {
                            <span class="status-pill @GetStatusClass(s.StatusType)">@s.StatusType</span>
                        }
                    </div>
                    <h2 class="spotlight-title">@SpotlightEntry.Title</h2>
                    @if (!string.IsNullOrWhiteSpace(SpotlightEntry.Genre))
                    {
                        <div class="spotlight-tags">
                            @foreach (var g in SpotlightEntry.Genre.Split(',', StringSplitOptions.TrimEntries))
                            {
                                <span class="genre-tag">@g</span>
                            }
                            @if (SpotlightEntry.Liked.HasValue)
                            {
                                <span class="genre-tag" style="@(SpotlightEntry.Liked.Value ? "color:#f472b6;border-color:rgba(244,114,182,0.3)" : "color:#e07060;border-color:rgba(224,112,96,0.3)")">
                                    @(SpotlightEntry.Liked.Value ? "♥ Liked" : "✕ Disliked")
                                </span>
                            }
                            @if (SpotlightEntry.IsFavorite)
                            {
                                <span class="genre-tag" style="color:var(--accent-gold);border-color:rgba(245,197,24,0.3)">★ Favorite</span>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(SpotlightEntry.Description))
                    {
                        <p class="spotlight-synopsis">@Truncate(SpotlightEntry.Description, 280)</p>
                    }
                    <div class="spotlight-stats">
                        <div class="spotlight-stat">
                            <span class="spotlight-stat-label">MAL Score</span>
                            <span class="spotlight-stat-value">@(SpotlightEntry.AverageRating?.ToString("F1") ?? "—")</span>
                        </div>
                        <div class="spotlight-stat">
                            <span class="spotlight-stat-label">My Rating</span>
                            <span class="spotlight-stat-value" style="color:var(--accent-gold)">@(SpotlightEntry.MyRating?.ToString("F1") ?? "—")</span>
                        </div>
                        <div class="spotlight-stat">
                            <span class="spotlight-stat-label">Episodes</span>
                            <span class="spotlight-stat-value">@(SpotlightEntry.EpisodeCount?.ToString() ?? "—")</span>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(SpotlightEntry.Notes))
                    {
                        <div class="spotlight-notes">@SpotlightEntry.Notes</div>
                    }
                    <div class="spotlight-actions">
                        <button class="btn btn-gold" @onclick="() => GoToDetail(SpotlightEntry.Id)">Full Entry →</button>
                        @if (!string.IsNullOrWhiteSpace(SpotlightEntry.TrailerUrl))
                        {
                            <a class="btn btn-outline" href="@SpotlightEntry.TrailerUrl" target="_blank">▶ Trailer</a>
                        }
                        <button class="btn btn-back" @onclick="CloseSpotlight">✕ Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowRandomPicker)
{
    <div class="spotlight-overlay" @onclick="CloseRandomPicker">
        <div class="random-picker-panel" @onclick:stopPropagation="true">
            <button class="spotlight-close" @onclick="CloseRandomPicker">✕</button>
            @if (RandomEntry == null)
            {
                <div class="random-picker-empty">
                    <p class="random-picker-title">No anime in your Plan to Watch or Plan to Read list!</p>
                    <p class="random-picker-sub">Add some first.</p>
                </div>
            }
            else
            {
                <div class="random-picker-body">
                    @if (!string.IsNullOrWhiteSpace(RandomEntry.CoverImageUrl))
                    {
                        <div class="random-picker-bg"
                             style="background-image:url('@RandomEntry.CoverImageUrl')"></div>
                    }
                    <div class="random-picker-content">
                        <div class="random-picker-inner">
                            @if (!string.IsNullOrWhiteSpace(RandomEntry.CoverImageUrl))
                            {
                                <img class="random-picker-poster"
                                     src="@RandomEntry.CoverImageUrl"
                                     alt="@RandomEntry.Title" />
                            }
                            <div class="random-picker-details">
                                <p class="random-picker-eyebrow">🎲 Tonight you should watch...</p>
                                <h2 class="random-picker-title">@RandomEntry.Title</h2>
                                <div class="random-picker-meta">
                                    @if (RandomEntry.EpisodeCount.HasValue)
                                    {
                                        <span class="detail-badge">@RandomEntry.EpisodeCount eps</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(RandomEntry.Genre))
                                    {
                                        @foreach (var g in RandomEntry.Genre.Split(',', StringSplitOptions.TrimEntries).Take(3))
                                        {
                                            <span class="genre-tag">@g</span>
                                        }
                                    }
                                    @if (RandomEntry.AverageRating.HasValue)
                                    {
                                        <span class="detail-badge">⭐ @RandomEntry.AverageRating.Value.ToString("F1")</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(RandomEntry.Description))
                                {
                                    <p class="random-picker-synopsis">@Truncate(RandomEntry.Description, 220)</p>
                                }
                                <div class="random-picker-actions">
                                    <button class="btn btn-gold" @onclick="() => GoToDetail(RandomEntry.Id)">View Entry →</button>
                                    <button class="btn btn-outline" @onclick="PickRandom">🎲 Pick Again</button>
                                    <button class="btn btn-back" @onclick="CloseRandomPicker">Cancel</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<AnimeEntry> AllAnime = new();
    private List<AnimeEntry> FilteredAnime = new();
    private string ActiveFilter = "All";
    private string SearchQuery = string.Empty;
    private string SortOrder = "recent";
    private string MediaFilter = "All";
    private string? ActiveGenre;
    private List<string> AvailableGenres = new();
    private bool IsLoading = true;
    private AnimeEntry? SpotlightEntry;

    protected override async Task OnInitializedAsync()
    {
        AllAnime = await AnimeService.GetAllAsync();
        AvailableGenres = AllAnime
            .Where(a => !string.IsNullOrWhiteSpace(a.Genre))
            .SelectMany(a => a.Genre!.Split(',', StringSplitOptions.TrimEntries))
            .Where(g => !string.IsNullOrWhiteSpace(g))
            .GroupBy(g => g)
            .OrderByDescending(g => g.Count())
            .Select(g => g.Key)
            .Take(20)
            .ToList();
        ApplyFilter();
        IsLoading = false;
    }

    private void SetFilter(string filter) { ActiveFilter = filter; ApplyFilter(); }
    private void SetMediaFilter(string filter) { MediaFilter = filter; ApplyFilter(); }
    private void SetGenre(string? genre) { ActiveGenre = genre; ApplyFilter(); }

    private void ApplyFilter()
    {
        var query = AllAnime.AsEnumerable();

        if (MediaFilter == "Anime")
            query = query.Where(a => a.Statuses.Any(s =>
                s.StatusType == "Watched" || s.StatusType == "Watching" ||
                s.StatusType == "Plan to Watch" || s.StatusType == "Dropped" ||
                s.StatusType == "On-Hold"));
        else if (MediaFilter == "Manga")
            query = query.Where(a => a.Statuses.Any(s =>
                s.StatusType == "Read" || s.StatusType == "Reading" ||
                s.StatusType == "Plan to Read"));

        if (ActiveFilter != "All")
            query = query.Where(a => a.Statuses.Any(s => s.StatusType == ActiveFilter));

        if (!string.IsNullOrWhiteSpace(SearchQuery))
            query = query.Where(a => a.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

        if (ActiveGenre != null)
            query = query.Where(a => a.Genre != null &&
                a.Genre.Split(',', StringSplitOptions.TrimEntries)
                       .Contains(ActiveGenre, StringComparer.OrdinalIgnoreCase));

        query = SortOrder switch
        {
            "alpha" => query.OrderBy(a => a.Title),
            "rating_desc" => query.OrderByDescending(a => a.MyRating ?? -1),
            "rating_asc" => query.OrderBy(a => a.MyRating ?? 999),
            "mal_desc" => query.OrderByDescending(a => a.AverageRating ?? -1),
            _ => query.OrderByDescending(a => a.DateAdded)
        };

        FilteredAnime = query.ToList();
    }

    private void OpenSpotlight(AnimeEntry entry) => SpotlightEntry = entry;
    private void CloseSpotlight() => SpotlightEntry = null;

    private void GoToDetail(int id)
    {
        CloseSpotlight();
        Nav.NavigateTo($"/anime/{id}/vault");
    }

    private async Task ToggleFavorite(AnimeEntry entry)
    {
        await AnimeService.ToggleFavoriteAsync(entry.Id);
        entry.IsFavorite = !entry.IsFavorite;
    }

    private string Truncate(string? s, int max) =>
        s == null ? "" : s.Length <= max ? s : s[..max].TrimEnd() + "…";

    private string GetStatusClass(string? status) => status switch
    {
        "Watched" => "status-watched",
        "Watching" => "status-watching",
        "Read" => "status-read",
        "Reading" => "status-reading",
        "Plan to Watch" => "status-plan",
        "Plan to Read" => "status-plan",
        "Dropped" => "status-dropped",
        "On-Hold" => "status-onhold",
        _ => ""
    };

    private bool ShowRandomPicker = false;
    private AnimeEntry? RandomEntry;
    private Random Rng = new();

    private void OpenRandomPicker() { ShowRandomPicker = true; PickRandom(); StateHasChanged(); }
    private void CloseRandomPicker() { ShowRandomPicker = false; RandomEntry = null; StateHasChanged(); }

    private void PickRandom()
    {
        var pool = AllAnime
            .Where(a => a.Statuses.Any(s =>
                s.StatusType == "Plan to Watch" || s.StatusType == "Plan to Read"))
            .ToList();
        RandomEntry = pool.Any() ? pool[Rng.Next(pool.Count)] : null;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchQuery = e.Value?.ToString() ?? string.Empty;
        ApplyFilter();
    }
}