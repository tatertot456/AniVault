@page "/favorites"
@inject AnimeService AnimeService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Favorites — AniVault</PageTitle>

<div class="section">
    <div class="section-header">
        <h1 class="section-title"><span style="color:var(--accent-gold)">★</span> Favorites</h1>
    </div>

    <div class="vault-controls">
        <select class="dev-select" @bind="SortOrder" @bind:after="ApplySort">
            <option value="recent">Recently Added</option>
            <option value="alpha">A → Z</option>
            <option value="rating_desc">My Rating ↓</option>
            <option value="rating_asc">My Rating ↑</option>
            <option value="mal_desc">MAL Score ↓</option>
        </select>
    </div>

    @if (IsLoading)
    {
        <div class="spinner-container">
            <div class="spinner"></div>
        </div>
    }
    else if (!FavoritesList.Any())
    {
        <div class="empty-state">
            <p>No favorites yet. Star some anime from the vault!</p>
        </div>
    }
    else
    {
        <div class="anime-grid">
            @foreach (var entry in SortedFavorites)
            {
                <div class="anime-card" @onclick="() => OpenSpotlight(entry)">
                    @if (!string.IsNullOrWhiteSpace(entry.CoverImageUrl))
                    {
                        <img class="anime-card-poster"
                             src="@entry.CoverImageUrl"
                             alt="@entry.Title poster"
                             loading="lazy" />
                    }
                    else
                    {
                        <div class="anime-card-no-art">NO ART</div>
                    }

                    <div class="anime-card-overlay">
                        <p class="anime-card-title">@entry.Title</p>
                        <span class="status-pill @GetStatusClass(entry.WatchStatus)">@entry.WatchStatus</span>
                    </div>

                    <div class="anime-card-hover-info">
                        @if (!string.IsNullOrWhiteSpace(entry.Description))
                        {
                            <p class="anime-card-synopsis">@Truncate(entry.Description, 180)</p>
                        }
                        @if (entry.Liked.HasValue)
                        {
                            <span class="anime-card-liked @(entry.Liked.Value ? "liked-yes" : "liked-no")">
                                @(entry.Liked.Value ? "♥ Liked" : "✕ Disliked")
                            </span>
                        }
                    </div>

                    @if (entry.MyRating.HasValue)
                    {
                        <span class="anime-card-score">@entry.MyRating.Value.ToString("F1")</span>
                    }
                    <span class="card-fav-btn fav-active">★</span>
                </div>
            }
        </div>
    }
</div>

<!-- Spotlight Modal -->
@if (SpotlightEntry != null)
{
    <div class="spotlight-overlay" @onclick="CloseSpotlight">
        <div class="spotlight-panel" @onclick:stopPropagation="true">

            @if (!string.IsNullOrWhiteSpace(SpotlightEntry.CoverImageUrl))
            {
                <div class="spotlight-bg"
                     style="background-image:url('@SpotlightEntry.CoverImageUrl')"></div>
            }

            <button class="spotlight-close" @onclick="CloseSpotlight">✕</button>

            <div class="spotlight-body">
                <div class="spotlight-poster-wrap">
                    @if (!string.IsNullOrWhiteSpace(SpotlightEntry.CoverImageUrl))
                    {
                        <img class="spotlight-poster"
                             src="@SpotlightEntry.CoverImageUrl"
                             alt="@SpotlightEntry.Title" />
                    }
                </div>

                <div class="spotlight-info">
                    <span class="status-pill @GetStatusClass(SpotlightEntry.WatchStatus)"
                          style="margin-bottom:0.75rem;display:inline-block;">
                        @SpotlightEntry.WatchStatus
                    </span>
                    <h2 class="spotlight-title">@SpotlightEntry.Title</h2>

                    @if (!string.IsNullOrWhiteSpace(SpotlightEntry.Genre))
                    {
                        <div class="spotlight-tags">
                            @foreach (var g in SpotlightEntry.Genre.Split(',', StringSplitOptions.TrimEntries))
                            {
                                <span class="genre-tag">@g</span>
                            }
                            @if (SpotlightEntry.Liked.HasValue)
                            {
                                <span class="genre-tag" style="@(SpotlightEntry.Liked.Value ? "color:#f472b6;border-color:rgba(244,114,182,0.3)" : "color:#e07060;border-color:rgba(224,112,96,0.3)")">
                                    @(SpotlightEntry.Liked.Value ? "♥ Liked" : "✕ Disliked")
                                </span>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(SpotlightEntry.Description))
                    {
                        <p class="spotlight-synopsis">@Truncate(SpotlightEntry.Description, 280)</p>
                    }

                    <div class="spotlight-stats">
                        <div class="spotlight-stat">
                            <span class="spotlight-stat-label">MAL Score</span>
                            <span class="spotlight-stat-value">@(SpotlightEntry.AverageRating?.ToString("F1") ?? "—")</span>
                        </div>
                        <div class="spotlight-stat">
                            <span class="spotlight-stat-label">My Rating</span>
                            <span class="spotlight-stat-value" style="color:var(--accent-gold)">@(SpotlightEntry.MyRating?.ToString("F1") ?? "—")</span>
                        </div>
                        <div class="spotlight-stat">
                            <span class="spotlight-stat-label">Episodes</span>
                            <span class="spotlight-stat-value">@(SpotlightEntry.EpisodeCount?.ToString() ?? "—")</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(SpotlightEntry.Notes))
                    {
                        <div class="spotlight-notes">@SpotlightEntry.Notes</div>
                    }

                    <div class="spotlight-actions">
                        <button class="btn btn-gold" @onclick="() => GoToDetail(SpotlightEntry.Id)">
                            Full Entry →
                        </button>
                        @if (!string.IsNullOrWhiteSpace(SpotlightEntry.TrailerUrl))
                        {
                            <a class="btn btn-outline" href="@SpotlightEntry.TrailerUrl" target="_blank">▶ Trailer</a>
                        }
                        <button class="btn btn-back" @onclick="CloseSpotlight">✕ Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<AnimeEntry> FavoritesList = new();
    private List<AnimeEntry> SortedFavorites = new();
    private bool IsLoading = true;
    private AnimeEntry? SpotlightEntry;
    private string SortOrder = "recent";

    protected override async Task OnInitializedAsync()
    {
        FavoritesList = await AnimeService.GetFavoritesAsync();
        ApplySort();
        IsLoading = false;
    }

    private void ApplySort()
    {
        SortedFavorites = SortOrder switch
        {
            "alpha" => FavoritesList.OrderBy(a => a.Title).ToList(),
            "rating_desc" => FavoritesList.OrderByDescending(a => a.MyRating ?? -1).ToList(),
            "rating_asc" => FavoritesList.OrderBy(a => a.MyRating ?? 999).ToList(),
            "mal_desc" => FavoritesList.OrderByDescending(a => a.AverageRating ?? -1).ToList(),
            _ => FavoritesList.OrderByDescending(a => a.DateAdded).ToList()
        };
    }

    private void OpenSpotlight(AnimeEntry entry) => SpotlightEntry = entry;
    private void CloseSpotlight() => SpotlightEntry = null;

    private void GoToDetail(int id)
    {
        CloseSpotlight();
        Nav.NavigateTo($"/anime/{id}");
    }

    private string Truncate(string? s, int max) =>
        s == null ? "" : s.Length <= max ? s : s[..max].TrimEnd() + "…";

    private string GetStatusClass(string? status) => status switch
    {
        "Watched" => "status-watched",
        "Watching" => "status-watching",
        "Read" => "status-read",
        "Reading" => "status-reading",
        "Plan to Watch" => "status-plan",
        "Plan to Read" => "status-plan",
        "Dropped" => "status-dropped",
        "On-Hold" => "status-onhold",
        _ => ""
    };
}