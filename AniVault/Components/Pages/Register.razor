@page "/register"
@rendermode InteractiveServer

<PageTitle>Register — AniVault</PageTitle>

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-logo">ANI<span>VAULT</span></div>
        <h2 class="auth-title">Create Account</h2>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="auth-error">
                @(Error == "mismatch" ? "Passwords do not match." : Uri.UnescapeDataString(Error))
            </div>
        }

        <form method="post" action="/register-post" class="auth-form">
            <AntiforgeryToken />
            <div class="dev-panel-field">
                <label class="dev-panel-label">Email</label>
                <input class="dev-input" type="email"
                       name="email"
                       placeholder="your@email.com"
                       required />
            </div>
            <div class="dev-panel-field">
                <label class="dev-panel-label">Password</label>
                <input class="dev-input" type="password"
                       name="password"
                       placeholder="Min 8 characters"
                       required />
            </div>
            <div class="dev-panel-field">
                <label class="dev-panel-label">Confirm Password</label>
                <input class="dev-input" type="password"
                       name="confirmPassword"
                       placeholder="Repeat password"
                       required />
            </div>
            <button type="submit" class="btn btn-gold auth-btn">Create Account</button>
        </form>

        <p class="auth-switch">
            Already have an account? <a href="/login">Sign In</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? Error { get; set; }
}