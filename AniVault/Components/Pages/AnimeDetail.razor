@page "/anime/{Id:int}"
@page "/anime/{Id:int}/{From}"
@inject AnimeService AnimeService
@inject NavigationManager Nav
@inject ToastService Toast
@rendermode InteractiveServer

<PageTitle>@(Entry?.Title ?? "Loading...") — AniVault</PageTitle>

@if (IsLoading)
{
    <div class="spinner-container">
        <div class="spinner"></div>
    </div>
}
else if (Entry == null)
{
    <div class="empty-state">
        <p>Anime not found. <a href="/">Go back to Gallery</a></p>
    </div>
}
else
{
    <div class="detail-shell">
        <button class="btn-back" @onclick="GoBack">← Back</button>

        <div class="detail-hero">
            <div class="detail-poster-wrap">
                @if (!string.IsNullOrWhiteSpace(Entry.CoverImageUrl))
                {
                    <img class="detail-poster" src="@Entry.CoverImageUrl" alt="@Entry.Title poster" />
                }
                else
                {
                    <div class="detail-poster-placeholder">NO ART</div>
                }
            </div>

            <div class="detail-info">
                <h1 class="detail-title">@Entry.Title</h1>

                <div class="detail-meta">
                    @if (Entry.Statuses.Any())
                    {
                        @foreach (var s in Entry.Statuses)
                        {
                            <span class="status-pill @GetStatusClass(s.StatusType)">@s.StatusType</span>
                        }
                    }
                    @if (Entry.EpisodeCount.HasValue)
                    {
                        <span class="detail-badge">@Entry.EpisodeCount eps</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Entry.Genre))
                    {
                        @foreach (var g in Entry.Genre.Split(',', StringSplitOptions.TrimEntries))
                        {
                            <span class="genre-tag">@g</span>
                        }
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Entry.Description))
                {
                    <p class="detail-synopsis">@Entry.Description</p>
                }

                <div class="detail-ratings">
                    @if (Entry.AverageRating.HasValue)
                    {
                        <div class="rating-block">
                            <span class="rating-label">MAL Rating</span>
                            <span class="rating-value">@Entry.AverageRating.Value.ToString("F1")</span>
                        </div>
                    }
                    @if (Entry.MyRating.HasValue)
                    {
                        <div class="rating-block">
                            <span class="rating-label">My Rating</span>
                            <span class="rating-value">@Entry.MyRating.Value.ToString("F1")</span>
                        </div>
                    }
                    @if (Entry.Liked.HasValue)
                    {
                        <div class="rating-block">
                            <span class="rating-label">Liked</span>
                            <span class="rating-value @(Entry.Liked.Value ? "liked-yes" : "liked-no")">
                                @(Entry.Liked.Value ? "♥ Yes" : "✕ No")
                            </span>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Entry.Notes))
                {
                    <div class="detail-notes">
                        <span class="rating-label">My Notes</span>
                        <p>@Entry.Notes</p>
                    </div>
                }

                <div class="detail-actions">
                    <button class="btn btn-gold" @onclick="ToggleFavorite">
                        @(Entry.IsFavorite ? "★ Favorited" : "☆ Add to Favorites")
                    </button>
                    <button class="btn btn-outline" @onclick="ToggleEdit">
                        @(IsEditing ? "✕ Cancel Edit" : "✏ Edit Entry")
                    </button>
                    <button class="btn btn-danger" @onclick="ConfirmDelete">
                        🗑 Remove
                    </button>
                </div>
            </div>
        </div>

        @if (IsEditing)
        {
            <div class="edit-panel">
                <h2 class="edit-panel-title">Edit Entry</h2>
                <div class="edit-panel-grid">

                    <div class="dev-panel-field dev-panel-field-full">
                        <label class="dev-panel-label">Status</label>
                        <div class="status-checkbox-grid">
                            @foreach (var status in AllStatuses)
                            {
                                var captured = status;
                                <label class="status-checkbox-label @(EditStatuses.Contains(captured) ? "status-checkbox-active" : "")">
                                    <input type="checkbox"
                                           checked="@EditStatuses.Contains(captured)"
                                           @onchange="() => ToggleEditStatus(captured)" />
                                    @captured
                                </label>
                            }
                        </div>
                    </div>

                    <div class="dev-panel-field">
                        <label class="dev-panel-label">My Rating (0–10)</label>
                        <input class="dev-input-small" type="number"
                               min="0" max="10" step="0.1"
                               placeholder="Leave blank to rate later"
                               @bind="EditRating" />
                    </div>

                    <div class="dev-panel-field">
                        <label class="dev-panel-label">Did you like it?</label>
                        <div class="liked-toggle">
                            <button class="liked-btn @(EditLiked == true ? "liked-btn-yes" : "")"
                                    @onclick='() => EditLiked = EditLiked == true ? null : true'>
                                ♥ Liked
                            </button>
                            <button class="liked-btn @(EditLiked == false ? "liked-btn-no" : "")"
                                    @onclick='() => EditLiked = EditLiked == false ? null : false'>
                                ✕ Disliked
                            </button>
                            <button class="liked-btn @(EditLiked == null ? "liked-btn-neutral" : "")"
                                    @onclick="() => EditLiked = null">
                                — Undecided
                            </button>
                        </div>
                    </div>

                    <div class="dev-panel-field">
                        <label class="dev-panel-label">Favorite?</label>
                        <div class="liked-toggle">
                            <button class="liked-btn @(EditFavorite ? "liked-btn-yes" : "")"
                                    @onclick="() => EditFavorite = true">
                                ★ Yes
                            </button>
                            <button class="liked-btn @(!EditFavorite ? "liked-btn-neutral" : "")"
                                    @onclick="() => EditFavorite = false">
                                ☆ No
                            </button>
                        </div>
                    </div>

                    <div class="dev-panel-field dev-panel-field-full">
                        <label class="dev-panel-label">Notes</label>
                        <textarea class="dev-textarea" rows="4"
                                  placeholder="Your thoughts, comments..."
                                  @bind="EditNotes"></textarea>
                    </div>

                </div>
                <div class="edit-panel-actions">
                    <button class="btn btn-gold" @onclick="SaveEdit">💾 Save Changes</button>
                    <button class="btn btn-back" @onclick="ToggleEdit">Cancel</button>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Entry.TrailerUrl))
        {
            <div class="detail-trailer">
                <h2 class="section-title">Trailer</h2>
                <div class="trailer-wrap">
                    <iframe src="@Entry.TrailerUrl"
                            frameborder="0"
                            allowfullscreen
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                    </iframe>
                </div>
            </div>
        }

        @if (ShowDeleteConfirm)
        {
            <div class="confirm-overlay">
                <div class="confirm-box">
                    <h3 class="confirm-title">Remove from Vault?</h3>
                    <p class="confirm-message">
                        Are you sure you want to remove <strong>@Entry.Title</strong> from your vault? This cannot be undone.
                    </p>
                    <div class="confirm-actions">
                        <button class="btn btn-danger" @onclick="DeleteEntry">Yes, Remove</button>
                        <button class="btn btn-back" @onclick="CancelDelete">Cancel</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public string? From { get; set; }

    private AnimeEntry? Entry;
    private bool IsLoading = true;
    private bool IsEditing = false;
    private bool ShowDeleteConfirm = false;

    private HashSet<string> EditStatuses = new();
    private decimal? EditRating;
    private bool? EditLiked;
    private bool EditFavorite;
    private string EditNotes = string.Empty;

    private readonly List<string> AllStatuses = new()
    {
        "Watching", "Watched",
        "Reading", "Read",
        "Plan to Watch", "Plan to Read",
        "On-Hold", "Dropped"
    };

    protected override async Task OnInitializedAsync()
    {
        Entry = await AnimeService.GetByIdAsync(Id);
        IsLoading = false;
    }

    private void GoBack()
    {
        if (From == "favorites") Nav.NavigateTo("/favorites");
        else if (From == "home") Nav.NavigateTo("/");
        else Nav.NavigateTo("/vault");
    }

    private void ToggleEdit()
    {
        if (Entry == null) return;
        IsEditing = !IsEditing;
        if (IsEditing)
        {
            EditStatuses = Entry.Statuses
                .Select(s => s.StatusType)
                .ToHashSet();
            EditRating = Entry.MyRating;
            EditLiked = Entry.Liked;
            EditFavorite = Entry.IsFavorite;
            EditNotes = Entry.Notes ?? string.Empty;
        }
    }

    private void ToggleEditStatus(string status)
    {
        if (EditStatuses.Contains(status))
            EditStatuses.Remove(status);
        else
            EditStatuses.Add(status);
    }

    private async Task SaveEdit()
    {
        if (Entry == null) return;
        Entry.MyRating = EditRating;
        Entry.Liked = EditLiked;
        Entry.IsFavorite = EditFavorite;
        Entry.Notes = string.IsNullOrWhiteSpace(EditNotes) ? null : EditNotes;
        await AnimeService.UpdateAsync(Entry);
        await AnimeService.SetStatusesAsync(Entry.Id, EditStatuses.ToList());
        Entry = await AnimeService.GetByIdAsync(Entry.Id);
        Toast.Show("Entry updated!", ToastType.Success);
        IsEditing = false;
    }

    private async Task ToggleFavorite()
    {
        if (Entry == null) return;
        await AnimeService.ToggleFavoriteAsync(Entry.Id);
        Entry.IsFavorite = !Entry.IsFavorite;
        Toast.Show(Entry.IsFavorite ? "Added to favorites!" : "Removed from favorites.", ToastType.Success);
    }

    private void ConfirmDelete() => ShowDeleteConfirm = true;
    private void CancelDelete() => ShowDeleteConfirm = false;

    private async Task DeleteEntry()
    {
        if (Entry == null) return;
        await AnimeService.DeleteAsync(Entry.Id);
        Toast.Show("Removed from vault.", ToastType.Info);
        Nav.NavigateTo("/vault");
    }

    private string GetStatusClass(string? status) => status switch
    {
        "Watched" => "status-watched",
        "Watching" => "status-watching",
        "Read" => "status-read",
        "Reading" => "status-reading",
        "Plan to Watch" => "status-plan",
        "Plan to Read" => "status-plan",
        "Dropped" => "status-dropped",
        "On-Hold" => "status-onhold",
        _ => ""
    };
}