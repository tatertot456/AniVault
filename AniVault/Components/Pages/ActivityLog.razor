@page "/activity"
@inject AnimeService AnimeService
@rendermode InteractiveServer

<PageTitle>Activity — AniVault</PageTitle>

<div class="section">
    <div class="section-header">
        <h1 class="section-title">Activity Log</h1>
        <span class="vault-count">@AllAnime.Count entries</span>
    </div>

    @if (IsLoading)
    {
        <div class="spinner-container">
            <div class="spinner"></div>
        </div>
    }
    else if (!AllAnime.Any())
    {
        <div class="empty-state">
            <p>No activity yet. Add some anime from the <a href="/dev">Dev Menu</a>!</p>
        </div>
    }
    else
    {
        <div class="activity-timeline">
            @foreach (var group in GroupedByDate)
            {
                <div class="activity-date-group">
                    <div class="activity-date-header">
                        <span class="activity-date-label">@FormatDate(group.Key)</span>
                        <span class="activity-date-count">@group.Value.Count entries</span>
                    </div>
                    @foreach (var entry in group.Value)
                    {
                        <div class="activity-row" @onclick="() => GoToDetail(entry.Id)">
                            <div class="activity-connector">
                                <div class="activity-dot @GetStatusClass(entry.WatchStatus)"></div>
                                <div class="activity-line"></div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(entry.CoverImageUrl))
                            {
                                <img class="activity-poster"
                                     src="@entry.CoverImageUrl"
                                     alt="@entry.Title" />
                            }
                            else
                            {
                                <div class="activity-poster activity-poster-empty">?</div>
                            }
                            <div class="activity-info">
                                <span class="activity-title">@entry.Title</span>
                                <div class="activity-meta">
                                    <span class="status-pill @GetStatusClass(entry.WatchStatus)">@entry.WatchStatus</span>
                                    @if (entry.MyRating.HasValue)
                                    {
                                        <span class="activity-rating">⭐ @entry.MyRating.Value.ToString("F1")</span>
                                    }
                                    @if (entry.Liked.HasValue)
                                    {
                                        <span class="activity-liked @(entry.Liked.Value ? "liked-yes" : "liked-no")">
                                            @(entry.Liked.Value ? "♥ Liked" : "✕ Disliked")
                                        </span>
                                    }
                                    @if (entry.IsFavorite)
                                    {
                                        <span style="color:var(--accent-gold)">★</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(entry.Notes))
                                {
                                    <p class="activity-notes">@Truncate(entry.Notes, 120)</p>
                                }
                            </div>
                            <span class="activity-time">@entry.DateAdded.ToString("h:mm tt")</span>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<AnimeEntry> AllAnime = new();
    private Dictionary<DateOnly, List<AnimeEntry>> GroupedByDate = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        AllAnime = await AnimeService.GetAllAsync();

        GroupedByDate = AllAnime
            .GroupBy(a => DateOnly.FromDateTime(a.DateAdded))
            .OrderByDescending(g => g.Key)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(a => a.DateAdded).ToList());

        IsLoading = false;
    }

    private void GoToDetail(int id) =>
        NavigationManager.NavigateTo($"/anime/{id}/activity");

    private string FormatDate(DateOnly date)
    {
        var today = DateOnly.FromDateTime(DateTime.Now);
        var yesterday = today.AddDays(-1);

        if (date == today) return "Today";
        if (date == yesterday) return "Yesterday";
        if (date >= today.AddDays(-7)) return date.ToString("dddd");
        return date.ToString("MMMM d, yyyy");
    }

    private string Truncate(string? s, int max) =>
        s == null ? "" : s.Length <= max ? s : s[..max].TrimEnd() + "…";

    private string GetStatusClass(string? status) => status switch
    {
        "Watched" => "status-watched",
        "Watching" => "status-watching",
        "Read" => "status-read",
        "Reading" => "status-reading",
        "Plan to Watch" => "status-plan",
        "Plan to Read" => "status-plan",
        "Dropped" => "status-dropped",
        "On-Hold" => "status-onhold",
        _ => ""
    };

    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
}