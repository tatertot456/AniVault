@page "/"
@inject AnimeService AnimeService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>AniVault — Home</PageTitle>

<section class="hero-splash">
    <div class="hero-glow"></div>
    <div class="hero-content">
        <div class="hero-logo">ANI<span>VAULT</span></div>
        <p class="hero-tagline">Your personal anime vault</p>
        <div class="hero-stats-row">
            <div class="hero-stat-pill">
                <span class="hero-stat-num">@TotalAnime</span>
                <span class="hero-stat-lbl">in vault</span>
            </div>
            <div class="hero-stat-pill">
                <span class="hero-stat-num">@TotalWatched</span>
                <span class="hero-stat-lbl">watched</span>
            </div>
            <div class="hero-stat-pill">
                <span class="hero-stat-num">@TotalFavorites</span>
                <span class="hero-stat-lbl">favorites</span>
            </div>
        </div>
        <a href="/vault" class="hero-cta">Browse the Vault ↓</a>
    </div>
</section>

@if (InProgress.Any())
{
    <div class="section">
        <div class="section-header">
            <h2 class="section-title">Currently Watching</h2>
            <a href="/vault" class="view-all-link">View All →</a>
        </div>
        <div class="anime-grid">
            @foreach (var entry in InProgress)
            {
                <div class="anime-card" @onclick="() => GoToDetail(entry.Id)">
                    @if (!string.IsNullOrWhiteSpace(entry.CoverImageUrl))
                    {
                        <img class="anime-card-poster"
                             src="@entry.CoverImageUrl"
                             alt="@entry.Title poster"
                             loading="lazy" />
                    }
                    else
                    {
                        <div class="anime-card-no-art">NO ART</div>
                    }
                    <div class="anime-card-overlay">
                        <p class="anime-card-title">@entry.Title</p>
                        <div class="card-status-pills">
                            @foreach (var s in entry.Statuses)
                            {
                                <span class="status-pill @GetStatusClass(s.StatusType)">@s.StatusType</span>
                            }
                        </div>
                    </div>
                    <div class="anime-card-hover-info">
                        @if (!string.IsNullOrWhiteSpace(entry.Description))
                        {
                            <p class="anime-card-synopsis">@Truncate(entry.Description, 180)</p>
                        }
                        @if (entry.Liked.HasValue)
                        {
                            <span class="anime-card-liked @(entry.Liked.Value ? "liked-yes" : "liked-no")">
                                @(entry.Liked.Value ? "♥ Liked" : "✕ Disliked")
                            </span>
                        }
                    </div>
                    @if (entry.MyRating.HasValue)
                    {
                        <span class="anime-card-score">@entry.MyRating.Value.ToString("F1")</span>
                    }
                </div>
            }
        </div>
    </div>
}

@if (RecentAnime.Any())
{
    <div class="section">
        <div class="section-header">
            <h2 class="section-title">@(InProgress.Any() ? "More from the Vault" : "Recently Added")</h2>
            <a href="/vault" class="view-all-link">View All →</a>
        </div>
        <div class="anime-grid">
            @foreach (var entry in RecentAnime)
            {
                <div class="anime-card" @onclick="() => GoToDetail(entry.Id)">
                    @if (!string.IsNullOrWhiteSpace(entry.CoverImageUrl))
                    {
                        <img class="anime-card-poster"
                             src="@entry.CoverImageUrl"
                             alt="@entry.Title poster"
                             loading="lazy" />
                    }
                    else
                    {
                        <div class="anime-card-no-art">NO ART</div>
                    }
                    <div class="anime-card-overlay">
                        <p class="anime-card-title">@entry.Title</p>
                        <div class="card-status-pills">
                            @foreach (var s in entry.Statuses)
                            {
                                <span class="status-pill @GetStatusClass(s.StatusType)">@s.StatusType</span>
                            }
                        </div>
                    </div>
                    <div class="anime-card-hover-info">
                        @if (!string.IsNullOrWhiteSpace(entry.Description))
                        {
                            <p class="anime-card-synopsis">@Truncate(entry.Description, 180)</p>
                        }
                        @if (entry.Liked.HasValue)
                        {
                            <span class="anime-card-liked @(entry.Liked.Value ? "liked-yes" : "liked-no")">
                                @(entry.Liked.Value ? "♥ Liked" : "✕ Disliked")
                            </span>
                        }
                    </div>
                    @if (entry.MyRating.HasValue)
                    {
                        <span class="anime-card-score">@entry.MyRating.Value.ToString("F1")</span>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private List<AnimeEntry> RecentAnime = new();
    private List<AnimeEntry> InProgress = new();
    private int TotalAnime;
    private int TotalWatched;
    private int TotalFavorites;

    protected override async Task OnInitializedAsync()
    {
        var all = await AnimeService.GetAllAsync();
        TotalAnime = all.Count;
        TotalWatched = all.Count(a => a.Statuses.Any(s =>
            s.StatusType == "Watched" || s.StatusType == "Read"));
        TotalFavorites = all.Count(a => a.IsFavorite);
        InProgress = all
            .Where(a => a.Statuses.Any(s =>
                s.StatusType == "Watching" || s.StatusType == "Reading"))
            .Take(6)
            .ToList();
        RecentAnime = all
            .Where(a => !a.Statuses.Any(s =>
                s.StatusType == "Watching" || s.StatusType == "Reading"))
            .Take(6)
            .ToList();
    }

    private void GoToDetail(int id) => Nav.NavigateTo($"/anime/{id}/home");

    private string Truncate(string? s, int max) =>
        s == null ? "" : s.Length <= max ? s : s[..max].TrimEnd() + "…";

    private string GetStatusClass(string? status) => status switch
    {
        "Watched" => "status-watched",
        "Watching" => "status-watching",
        "Read" => "status-read",
        "Reading" => "status-reading",
        "Plan to Watch" => "status-plan",
        "Plan to Read" => "status-plan",
        "Dropped" => "status-dropped",
        "On-Hold" => "status-onhold",
        _ => ""
    };
}